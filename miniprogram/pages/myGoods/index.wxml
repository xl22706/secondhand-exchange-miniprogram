<view class="container">
  <view class="goods-list" wx:if="{{goodsList.length > 0}}">
    <view class="goods-item" wx:for="{{goodsList}}" wx:key="_id">
      <image class="goods-image" src="{{item.images[0] || '/assets/images/placeholder.png'}}" mode="aspectFill" />
      <view class="goods-info">
        <view class="goods-title">{{item.title}}</view>
        <view class="goods-meta">
          <text class="status-badge" wx:if="{{item.status === 'available'}}" style="color: #07c160; border-color: #07c160;">可交换</text>
          <text class="status-badge" wx:if="{{item.status === 'exchanged'}}" style="color: #999; border-color: #999;">已交换</text>
          <text class="status-badge" wx:if="{{item.status === 'offline'}}" style="color: #ff9900; border-color: #ff9900;">已下架</text>
        </view>
        <view class="goods-detail">{{item.category}} · {{item.condition}}</view>
        <view class="goods-time">{{item.createTime}}</view>
      </view>
      <view class="goods-actions">
        <view class="action-btn btn-edit" data-goods-id="{{item._id}}" bindtap="onEdit">编辑</view>
        <view class="action-btn btn-delete" data-goods-id="{{item._id}}" bindtap="onDelete">删除</view>
        <view class="action-btn btn-offline" wx:if="{{item.status === 'available'}}" data-goods-id="{{item._id}}" bindtap="onOffline">下架</view>
      </view>
    </view>
    <view class="load-more" wx:if="{{loading}}">加载中...</view>
    <view class="no-more" wx:if="{{!hasMore && goodsList.length > 0}}">没有更多了</view>
  </view>

  <view class="empty-state" wx:if="{{goodsList.length === 0 && !loading}}">
    <text>你还没有发布物品，去发布一个吧~</text>
  </view>
</view>
