.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
  box-sizing: border-box;
}

.goods-list {
  display: flex;
  flex-direction: column;
}

.goods-item {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.goods-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
}

.goods-title {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 12rpx;
}

.goods-meta {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.status-badge {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  border: 1rpx solid;
  margin-right: 12rpx;
}

.goods-detail {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.goods-time {
  font-size: 22rpx;
  color: #bbb;
}

.goods-actions {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 16rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  text-align: center;
  border: 1rpx solid;
}

.btn-edit {
  color: #07c160;
  border-color: #07c160;
}

.btn-delete {
  color: #e64340;
  border-color: #e64340;
}

.btn-offline {
  color: #ff9900;
  border-color: #ff9900;
}

.load-more,
.no-more {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  padding: 20rpx 0;
}

.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60vh;
  font-size: 28rpx;
  color: #999;
}
