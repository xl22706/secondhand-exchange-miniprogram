.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.user-card {
  height: 240rpx;
  background: linear-gradient(135deg, #07c160, #10b981);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #ffffff;
  background-color: #e0e0e0;
}

.nickname {
  margin-top: 16rpx;
  font-size: 32rpx;
  color: #ffffff;
  font-weight: 500;
}

.login-btn {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #ffffff;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 32rpx;
  padding: 8rpx 32rpx;
  line-height: 1.6;
  border: none;
}

.login-btn::after {
  border: none;
}

.menu-card {
  background-color: #ffffff;
  margin: -40rpx 20rpx 20rpx;
  border-radius: 24rpx;
  padding: 0 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #333;
}

.arrow-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.4;
}
