page {
  background-color: #f5f5f5;
}

.container {
  padding-bottom: 120rpx;
}

.goods-swiper {
  height: 500rpx;
}

.swiper-image {
  width: 100%;
  height: 500rpx;
}

.info-card {
  position: relative;
  background-color: #ffffff;
  border-radius: 24rpx;
  margin-top: -40rpx;
  padding: 30rpx;
  z-index: 1;
}

.goods-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.goods-tags {
  display: flex;
  margin-bottom: 20rpx;
}

.tag {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
}

.condition-tag {
  background-color: #e6f7ed;
  color: #07c160;
}

.category-tag {
  background-color: #f5f5f5;
  color: #666;
}

.goods-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.goods-location {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #666;
}

.location-icon {
  margin-right: 8rpx;
}

.goods-expect {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.expect-label {
  color: #333;
  font-weight: bold;
}

.publisher-card {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  margin-top: 20rpx;
  padding: 24rpx 30rpx;
}

.publisher-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.publisher-info {
  display: flex;
  flex-direction: column;
}

.publisher-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 6rpx;
}

.publish-time {
  font-size: 24rpx;
  color: #999;
}

.footer-placeholder {
  height: 40rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  border-top: 1rpx solid #eee;
  z-index: 10;
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  font-size: 30rpx;
  border-radius: 40rpx;
}

.btn-edit {
  flex: 1;
  margin-right: 20rpx;
  background-color: #ffffff;
  color: #07c160;
  border: 2rpx solid #07c160;
}

.btn-delete {
  flex: 1;
  background-color: #ff4d4f;
  color: #ffffff;
}

.btn-exchange {
  width: 100%;
  background-color: #07c160;
  color: #ffffff;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal-content {
  width: 80%;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 24rpx;
}

.modal-textarea {
  width: 100%;
  height: 200rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 16rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 24rpx;
}

.modal-actions {
  display: flex;
  justify-content: space-between;
}

.modal-btn {
  flex: 1;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  border-radius: 38rpx;
}

.modal-cancel {
  margin-right: 20rpx;
  background-color: #f5f5f5;
  color: #666;
}

.modal-confirm {
  background-color: #07c160;
  color: #ffffff;
}
