<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <input
      class="search-input"
      placeholder="搜索物品名称"
      value="{{keyword}}"
      bindinput="onKeywordInput"
      bindconfirm="onSearch"
    />
    <view class="search-btn" bindtap="onSearch">搜索</view>
  </view>

  <!-- 分类 Tab -->
  <scroll-view class="category-scroll" scroll-x enable-flex>
    <view class="category-list">
      <view
        wx:for="{{categories}}"
        wx:key="value"
        class="category-item {{category === item.value ? 'active' : ''}}"
        data-value="{{item.value}}"
        bindtap="onCategoryChange"
      >
        {{item.label}}
      </view>
    </view>
  </scroll-view>

  <!-- 物品列表 -->
  <view class="goods-grid" wx:if="{{goodsList.length > 0}}">
    <view
      class="goods-card"
      wx:for="{{goodsList}}"
      wx:key="_id"
      data-id="{{item._id}}"
      bindtap="goToDetail"
    >
      <image
        class="goods-image"
        src="{{item.images[0] || '/images/default-goods-image.png'}}"
        mode="aspectFill"
      />
      <view class="goods-info">
        <view class="goods-title">{{item.title}}</view>
        <view class="goods-tags">
          <view class="tag condition-tag">{{item.condition}}</view>
        </view>
        <view class="goods-user">
          <image
            class="user-avatar"
            src="{{item.ownerAvatar || '/images/avatar.png'}}"
          />
          <text class="user-nickname">{{item.ownerNickName || '未知用户'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{goodsList.length === 0 && !loading}}">
    <image class="empty-icon" src="/images/default-goods-image.png" />
    <text class="empty-text">暂无物品，去发布一个吧~</text>
  </view>

  <!-- 加载提示 -->
  <view class="loading-more" wx:if="{{loading && goodsList.length > 0}}">
    <text>加载中...</text>
  </view>
  <view class="no-more" wx:if="{{!hasMore && goodsList.length > 0}}">
    <text>没有更多了</text>
  </view>
</view>
